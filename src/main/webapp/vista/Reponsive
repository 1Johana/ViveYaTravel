/* Reset y tipografía fluida */
*{ box-sizing: border-box; }
html, body{ margin:0; padding:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; }
:root{
  --maxw: 1200px;
  --gap: 1rem;
  --radius: 12px;
  --text: clamp(14px, 1.6vw, 16px);
  --h1: clamp(22px, 4.5vw, 34px);
  --h2: clamp(18px, 3.5vw, 28px);
}
h1{ font-size: var(--h1); margin:0 0 .5em; }
h2{ font-size: var(--h2); margin:1.25em 0 .4em; }

/* Utilidades base */
.container{ width: min(100% - 2rem, var(--maxw)); margin-inline:auto; }
.section{ padding: 1rem 0; }
img, video{ max-width:100%; height:auto; display:block; }
.scroll-x{ overflow-x:auto; }

/* Layout móvil por defecto */
.grid{ display:grid; grid-template-columns: 1fr; gap: var(--gap); }
.card{ background:#fff; border:1px solid #eaeaea; border-radius: var(--radius); padding: 1rem; }

/* Navbar (móvil por defecto) */
.navbar{ display:flex; align-items:center; justify-content:space-between; padding:.75rem 0; }
.brand{ font-weight:700; }
.menu-toggle{ background:none; border:1px solid #ddd; border-radius:10px; padding:.4rem .6rem; font-size:1rem; }
.nav-links{ display:none; flex-direction:column; gap:.5rem; padding:.75rem 0; }
.nav-links a{ text-decoration:none; padding:.5rem .75rem; border-radius:8px; }
.nav-links a:is(:hover,:focus){ background:#f5f5f5; }

/* Tablas como tarjetas en móvil */
.table{ width:100%; border-collapse:collapse; }
.table th, .table td{ padding:.75rem; border-bottom:1px solid #eee; }
@media (max-width: 640px){
  .table thead{ display:none; }
  .table tr{ display:block; border:1px solid #eee; border-radius:10px; margin-bottom:.75rem; }
  .table td{ display:flex; justify-content:space-between; gap:1rem; }
  .table td::before{ content: attr(data-label); font-weight:600; }
}

/* Formularios */
form{ display:grid; gap:.75rem; }
input, select, textarea{ width:100%; padding:.6rem .75rem; border:1px solid #ddd; border-radius:10px; }

/* Breakpoints (ajusta si quieres) */
@media (min-width: 640px){            /* móvil grande */
  .grid{ grid-template-columns: repeat(2, 1fr); }
  .nav-links{ display:flex; flex-direction:row; gap:1rem; }
  .menu-toggle{ display:none; }
}
@media (min-width: 768px){            /* tablet */
  .grid{ grid-template-columns: repeat(3, 1fr); }
  .section{ padding: 1.25rem 0; }
}
@media (min-width: 1024px){           /* laptop */
  .grid{ grid-template-columns: repeat(4, 1fr); }
  .layout{ display:grid; grid-template-columns: 240px 1fr; gap: var(--gap); }
  .sidebar{ position:sticky; top:1rem; align-self:start; }
}
@media (min-width: 1280px){           /* desktop ancho */
  :root{ --maxw: 1320px; }
}
