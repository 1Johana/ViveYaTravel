/* ===== Reset & fuente ===== */
@import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&display=swap');

* { box-sizing: border-box; margin: 0; padding: 0; }

:root{
  --header-h: 64px;
  --maxw: 1200px;
  --gap: 1rem;
  --text: clamp(14px, 1.6vw, 16px);
}

html, body { font-family: Arial, sans-serif; }

body {
  margin: 0;
  padding: 0;
  font-size: var(--text);
}

/* Título (arregla tipografía y comillas) */
h1{
  display: inline-block;
  position: relative;
  color: pink;
  font-family: "Dancing Script", cursive;
}
h1::after, h1::before{
  content:'';
  position: absolute;
  width: 120px;
  height: 3px;
  background-color: #0288d1;
  top:0.6em;
}
h1::before{ left: -140px; }
h1::after{ right: -140px; }
/* ===== Header ===== */
.header {
  width: 100%;
  background-color: #085394;
  color: white;
  position: relative;
  z-index: 99;
}

/* Contenedor: usa height auto + padding en vez de height fija */
.contHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: var(--maxw);
  margin: 0 auto;
  padding: .5rem 1rem; /* móvil */
  min-height: var(--header-h);
}

/* Logo: corrige selector (era "img .logo") y elimina el hack de padding-top */
.logo { display:flex; align-items:center; }
.logo img { height: 48px; width: auto; display:block; }

/* Iconos/usuario */
.usuario-container{ display:flex; align-items:center; gap:.5rem; margin-left:auto; }
.usuario{ color:#fff; font-size: 1rem; }
.usuario a{ color:#fff; font-size:.9rem; text-decoration:none; }
.usuario:hover{ color:#e5e5e5; }
.cerrar{ font-size: 1.25rem; color:#C40C0C; }
.carrito{ color:#fff; font-size: 1.25rem; }

/* ===== Navbar: móvil por defecto (vertical, oculto) ===== */
.navbar{ padding-top:.25rem; }
.navbar nav ul.menu{ list-style:none; padding:0; margin:0; display:none; flex-direction:column; gap:.5rem; }
.navbar nav ul.menu li{ display:block; }
.navbar nav ul.menu li a{
  text-decoration:none; color:#fff; font-weight:bold; padding:.5rem .75rem; border-radius:8px; display:block;
}
.navbar nav ul.menu li a:hover{ background:#fff; color:#085394; }

/* Botón hamburguesa (añádelo en tu HTML) */
.menu-toggle{
  background: transparent;
  border:1px solid rgba(255,255,255,.5);
  color:#fff; border-radius:10px;
  padding:.35rem .6rem;
  font-size:1rem; cursor:pointer;
}

/* Estado abierto (lo alternas con JS) */
.menu.is-open{ display:flex; }

/* ===== Breakpoints ===== */
@media (min-width: 640px){
  .contHeader{ padding: .75rem 1rem; }
}

@media (min-width: 768px){
  /* Tablet: menú horizontal visible, sin hamburguesa */
  .menu-toggle{ display:none; }
  .navbar nav ul.menu{
    display:flex !important; /* visible siempre */
    flex-direction:row; gap:1rem;
  }
  .navbar nav ul.menu li{ display:inline-block; margin:0; }
}

@media (min-width: 1024px){
  .contHeader{ padding: .75rem 1rem; }
  .logo img{ height: 56px; }
}
<!-- cerca del cierre de </body> -->
<script>
  (function(){
    const btn = document.querySelector('.menu-toggle');
    const menu = document.querySelector('.menu');
    if(!btn || !menu) return;
    btn.addEventListener('click', ()=>{
      menu.classList.toggle('is-open');
      const open = menu.classList.contains('is-open');
      btn.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
