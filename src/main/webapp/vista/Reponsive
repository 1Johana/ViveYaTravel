/* Base que convive con header.css */
.container { max-width: 1200px; margin: 0 auto; padding-inline: 1rem; }
.heading-1{ text-align:center; font-weight:500; font-size: clamp(1.5rem, 3vw, 3rem); color:#0288d1; }
.container-features{
  display:grid;
  grid-template-columns: 1fr; /* móvil */
  gap: 1rem;
  padding: 1.5rem 0;
}
@media (min-width: 640px){
  .container-features{ grid-template-columns: repeat(2,1fr); gap:1.5rem; }
}
@media (min-width: 1024px){
  .container-features{ grid-template-columns: repeat(4,1fr); gap:2rem; }
}

.card-feature{
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem;
  background:#fff; border-radius:1rem; padding:1rem 0; box-shadow:0 4px 6px rgba(0,0,0,.1);
}
.card-feature i{ font-size:2rem; }
.feature-content span{ font-weight:700; font-size:1rem; color:#0288d1; }
.top-products{ display:flex; flex-direction:column; gap:1.25rem; margin-bottom:2rem; }
.container-options{
  display:flex; flex-wrap:wrap; justify-content:center; gap:.75rem; margin-bottom:1rem;
}
.container-options span{
  background:#e0f7fa; color:#0b3b4a;
  padding:.6rem 1.25rem; font-size:1rem; border-radius:2rem; cursor:pointer; transition:.3s;
}
.container-options span:hover{ background:#81d4fa; color:#fff; }
.container-options span.active{ background:#0288d1; color:#fff; }

/* grid productos */
.container-products{
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); /* más amigable en móvil */
  gap: 1.25rem;
}
@media (min-width: 768px){
  .container-products{ gap: 2rem; }
}
@media (min-width: 1024px){
  .container-products{ gap: 2.5rem; }
}

/* tarjetas */
.card-product{ background:#fff; padding:1rem; border-radius:.5rem; cursor:pointer; box-shadow:0 0 2px rgba(0,0,0,.1); transition: transform .3s, box-shadow .3s; }
.card-product:hover{ transform: translateY(-.25rem); box-shadow:0 4px 8px rgba(0,0,0,.2); }

.container-img img{ width:100%; border-radius:.5rem; }

/* botón flotante de acciones: trae más “cerca” en móvil */
.button-group{
  display:flex; flex-direction:column; gap:.75rem;
  position:absolute; top:0; right:-2.25rem; z-index:-1; transition:all .4s;
}
.card-product:hover .button-group{ z-index:0; right:-.5rem; }
@media (max-width: 640px){
  .button-group{ right:-1rem; } /* más accesible en pantallas pequeñas */
}
.top-categories{ display:flex; flex-direction:column; gap:1.5rem; margin-bottom:2rem; }
.container-categories{
  display:grid;
  grid-template-columns: 1fr; /* móvil */
  gap: 1rem;
}
@media (min-width: 640px){
  .container-categories{ grid-template-columns: repeat(2,1fr); gap:1.25rem; }
}
@media (min-width: 1024px){
  .container-categories{ grid-template-columns: repeat(3,1fr); gap:1.5rem; }
}

.card-category{
  height: clamp(14rem, 35vw, 20rem);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  border-radius: 1.25rem; gap: 1rem; position:relative; overflow:hidden;
